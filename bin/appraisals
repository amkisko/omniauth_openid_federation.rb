#!/usr/bin/env ruby

# Run appraisal tests locally (default: Polyrun parallel-rspec, same idea as CI).
# Usage:
#   bin/appraisals                    # parallel-rspec for all appraisal gemfiles
#   bin/appraisals rails6             # parallel-rspec for Rails 6 only
#   bin/appraisals rails6 rails72     # parallel-rspec for specific versions
#   bin/appraisals rails6 rspec       # serial RSpec for Rails 6 (focused/debug)
#   bin/appraisals rails6 rake spec   # Run rake spec for Rails 6

require "bundler/setup"

APPRAISALS_FILE = File.join(File.dirname(File.dirname(File.expand_path(__FILE__))), "Appraisals")

unless File.exist?(APPRAISALS_FILE)
  $stderr.puts "Error: Cannot find Appraisals file at #{APPRAISALS_FILE}"
  exit 1
end

AVAILABLE_APPRAISALS = File.read(APPRAISALS_FILE, encoding: "UTF-8")
  .scan(/appraise\s+"([^"]+)"/)
  .flatten
  .freeze

SUPPORTED_RAILS_APPRAISALS = %w[rails6 rails72 rails8 rails8_ruby4].freeze

# Default suite: polyrun parallel-rspec (run-shards + merge-coverage) under each appraisal gemfile.
DEFAULT_POLYRUN_CMD = ["--", "bundle", "exec", "polyrun", "parallel-rspec", "--workers", "5", "-c", "polyrun.yml"].freeze

def usage
  puts <<~USAGE
    Usage: bin/appraisals [appraisal_name...] [command]

    Examples:
      bin/appraisals                          # Run polyrun parallel-rspec for all appraisals
      bin/appraisals rails6                   # parallel-rspec for Rails 6
      bin/appraisals rails6 rails72           # parallel-rspec for Rails 6 and 7.2
      bin/appraisals rails6 rspec             # serial RSpec for Rails 6
      bin/appraisals rails6 rake spec         # Run rake spec for Rails 6

    Available appraisals: #{AVAILABLE_APPRAISALS.join(', ')}
    Supported Rails appraisals (default): #{SUPPORTED_RAILS_APPRAISALS.join(', ')}
  USAGE
  exit 1
end

def parse_args
  args = ARGV.dup

  # Handle help flags
  if args.include?("--help") || args.include?("-h")
    usage
  end

  return [SUPPORTED_RAILS_APPRAISALS, DEFAULT_POLYRUN_CMD.dup] if args.empty?

  appraisals = []
  command = []

  args.each do |arg|
    if AVAILABLE_APPRAISALS.include?(arg)
      appraisals << arg
    else
      command << arg
    end
  end

  appraisals = AVAILABLE_APPRAISALS if appraisals.empty?
  command = DEFAULT_POLYRUN_CMD.dup if command.empty?

  [appraisals, command]
end

def run_appraisal(appraisal, command)
  puts "\n" + "=" * 80
  puts "Running #{appraisal} with: #{command.join(' ')}"
  puts "=" * 80

  root = File.expand_path(File.join(__dir__, ".."))
  Dir.chdir(root) do
    return false unless system("bundle", "exec", "polyrun", "build-paths", "-c", "polyrun.yml")

    cmd = ["bundle", "exec", "appraisal", appraisal] + command
    system(*cmd)
  end
end

appraisals, command = parse_args

unless appraisals.all? { |a| AVAILABLE_APPRAISALS.include?(a) }
  puts "Error: Invalid appraisal(s)"
  usage
end

results = {}
appraisals.each do |appraisal|
  results[appraisal] = run_appraisal(appraisal, command)
end

puts "\n" + "=" * 80
puts "Summary"
puts "=" * 80
appraisals.each do |appraisal|
  status = results[appraisal] ? "✓ PASSED" : "✗ FAILED"
  puts "#{appraisal}: #{status}"
end

exit 0 if results.values.all?
exit 1
